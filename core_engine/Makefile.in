	-rm -f src/processor/src/$(DEPDIR)/opencfu-Step_ColourCluster.Po
	-rm -f src/processor/src/$(DEPDIR)/opencfu-Step_FiltGUI.Po
	-rm -f src/processor/src/$(DEPDIR)/opencfu-Step_FiltHS.Po
	-rm -f src/processor/src/$(DEPDIR)/opencfu-Step_FiltIPosition2D.Po
	-rm -f src/processor/src/$(DEPDIR)/opencfu-Step_FiltLik.Po
	-rm -f src/processor/src/$(DEPDIR)/trainer-ContourFamily.Po
	-rm -f src/processor/src/$(DEPDIR)/trainer-Features.Po
	-rm -f src/processor/src/$(DEPDIR)/trainer-Predictor.Po
	-rm -f Makefile
